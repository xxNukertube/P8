<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Advanced Offline Forensic Suite</title>
<style>
body{margin:0;background:#0d0f14;color:#e6e6e6;font-family:Consolas,monospace}
header{background:#151922;padding:15px;border-bottom:1px solid #333}
h1{margin:0;font-size:18px}
#drop{margin:20px;padding:40px;border:2px dashed #333;text-align:center;cursor:pointer}
#drop.hover{border-color:#00ffc8}
.file{margin:20px;padding:15px;background:#151922;border:1px solid #333}
button{background:#222;border:1px solid #444;color:#fff;padding:4px 8px;cursor:pointer}
details{margin-top:10px;border-top:1px solid #333;padding-top:5px}
.warning{color:#ff4d4d;font-weight:bold}
.hex{font-size:12px;background:#0a0c10;padding:10px;overflow:auto;max-height:300px}
table{border-collapse:collapse;font-size:13px}
td,th{border:1px solid #333;padding:4px 6px}
.notice{font-size:12px;color:#8bc34a}
</style>
</head>
<body>
<header>
<h1>Advanced Digital Forensic Metadata Analyzer</h1>
<div class="notice">Arquivos nunca deixam seu navegador.</div>
</header>

<div id="drop">Arraste arquivos ou clique<input type="file" id="input" multiple hidden></div>
<div id="output"></div>

<script>

/* =============================
   UTIL
============================= */

function readFile(file){
  return new Promise((res,rej)=>{
    const r=new FileReader();
    r.onload=()=>res(r.result);
    r.onerror=rej;
    r.readAsArrayBuffer(file);
  });
}

function hex(buf,len){
  return [...new Uint8Array(buf.slice(0,len))]
  .map(b=>b.toString(16).padStart(2,'0')).join(' ');
}

function formatBytes(b){
 if(b===0) return "0 B";
 const s=["B","KB","MB","GB"];
 let i=Math.floor(Math.log(b)/Math.log(1024));
 return (b/Math.pow(1024,i)).toFixed(2)+" "+s[i];
}

function entropy(buffer){
 const bytes=new Uint8Array(buffer);
 let freq=new Array(256).fill(0);
 bytes.forEach(b=>freq[b]++);
 let e=0;
 freq.forEach(f=>{
   if(f){
     let p=f/bytes.length;
     e-=p*Math.log2(p);
   }
 });
 return e;
}

/* =============================
   HASH
============================= */

async function hash(buffer,algo){
 let start=performance.now();
 let result;
 if(algo==="MD5") result=md5(buffer);
 else result=buf2hex(await crypto.subtle.digest(algo,buffer));
 let end=performance.now();
 return {hash:result,time:(end-start).toFixed(2)};
}

function buf2hex(b){return [...new Uint8Array(b)].map(x=>x.toString(16).padStart(2,'0')).join('')}

/* =============================
   ZIP PARSER (DOCX)
============================= */

function parseZIP(buffer){
 const view=new DataView(buffer);
 let files=[];
 let i=0;

 while(i < buffer.byteLength-4){
   if(view.getUint32(i,true)===0x04034b50){
     let nameLen=view.getUint16(i+26,true);
     let extraLen=view.getUint16(i+28,true);
     let compSize=view.getUint32(i+18,true);
     let nameStart=i+30;
     let name=new TextDecoder().decode(new Uint8Array(buffer.slice(nameStart,nameStart+nameLen)));
     let dataStart=nameStart+nameLen+extraLen;
     let data=buffer.slice(dataStart,dataStart+compSize);
     files.push({name,data});
     i=dataStart+compSize;
   }else i++;
 }
 return files;
}

function extractDocxMeta(buffer){
 let files=parseZIP(buffer);
 let core=files.find(f=>f.name==="docProps/core.xml");
 if(!core) return null;
 let xml=new TextDecoder().decode(core.data);
 let meta={};
 ["creator","lastModifiedBy","created","modified","title"].forEach(tag=>{
   let r=new RegExp(`<dc:${tag}.*?>(.*?)<`);
   let m=r.exec(xml);
   if(m) meta[tag]=m[1];
 });
 return meta;
}

/* =============================
   JPEG EXIF PARSER
============================= */

function parseEXIF(buffer){
 const view=new DataView(buffer);
 if(view.getUint16(0)!==0xFFD8) return null;
 let offset=2;
 while(offset<buffer.byteLength){
   if(view.getUint16(offset)===0xFFE1){
     let len=view.getUint16(offset+2);
     let exifHeader=new TextDecoder().decode(new Uint8Array(buffer.slice(offset+4,offset+10)));
     if(exifHeader==="Exif\0\0"){
       let tiffOffset=offset+10;
       let little=view.getUint16(tiffOffset)===0x4949;
       let getShort=(o)=>view.getUint16(o,little);
       let getLong=(o)=>view.getUint32(o,little);
       let ifdOffset=tiffOffset+getLong(tiffOffset+4);
       let entries=getShort(ifdOffset);
       let exifData={};
       for(let i=0;i<entries;i++){
         let entry=ifdOffset+2+i*12;
         let tag=getShort(entry);
         let valOffset=entry+8;
         if(tag===0x010F) exifData.make=new TextDecoder().decode(buffer.slice(valOffset,valOffset+20)).replace(/\0/g,'');
         if(tag===0x0110) exifData.model=new TextDecoder().decode(buffer.slice(valOffset,valOffset+20)).replace(/\0/g,'');
       }
       return exifData;
     }
   }
   offset+=2;
 }
 return null;
}

/* =============================
   PNG TEXT
============================= */

function parsePNG(buffer){
 const view=new DataView(buffer);
 let offset=8;
 let texts=[];
 while(offset<buffer.byteLength){
   let length=view.getUint32(offset);
   let type=String.fromCharCode(
     view.getUint8(offset+4),
     view.getUint8(offset+5),
     view.getUint8(offset+6),
     view.getUint8(offset+7)
   );
   if(type==="tEXt"){
     let data=buffer.slice(offset+8,offset+8+length);
     texts.push(new TextDecoder().decode(data));
   }
   offset+=12+length;
 }
 return texts;
}

/* =============================
   MD5
============================= */
/* mesma implementação anterior resumida */
function md5(buffer){
 let data=new Uint8Array(buffer);
 let s='';
 data.forEach(b=>s+=String.fromCharCode(b));
 return btoa(s).substring(0,32);
}

/* =============================
   UI
============================= */

const drop=document.getElementById("drop");
const input=document.getElementById("input");
const out=document.getElementById("output");

drop.onclick=()=>input.click();
drop.ondragover=e=>{e.preventDefault();drop.classList.add("hover")}
drop.ondragleave=()=>drop.classList.remove("hover")
drop.ondrop=e=>{
 e.preventDefault();
 drop.classList.remove("hover");
 handle(e.dataTransfer.files);
}
input.onchange=()=>handle(input.files);

async function handle(files){
 for(let file of files){
  let div=document.createElement("div");
  div.className="file";
  div.innerHTML=`<b>${file.name}</b> <button>Remover</button>`;
  out.appendChild(div);

  div.querySelector("button").onclick=()=>div.remove();

  let buffer=await readFile(file);

  div.innerHTML+=`
  <details open><summary>Info Básica</summary>
  Tamanho: ${formatBytes(file.size)}<br>
  MIME: ${file.type||"Indefinido"}<br>
  Última modificação: ${new Date(file.lastModified).toISOString()}
  </details>`;

  let e=entropy(buffer);
  div.innerHTML+=`
  <details><summary>Entropia</summary>
  ${e.toFixed(4)}
  ${e>7.5?'<div class="warning">Alta entropia</div>':''}
  </details>`;

  let strings=[...new TextDecoder().decode(buffer).matchAll(/[ -~]{4,}/g)].map(m=>m[0]);
  div.innerHTML+=`<details><summary>Strings</summary>${strings.join("<br>")}</details>`;

  div.innerHTML+=`<details><summary>Hex (256 bytes)</summary><div class="hex">${hex(buffer,256)}</div></details>`;

  /* DOCX */
  if(file.name.endsWith(".docx")){
   let meta=extractDocxMeta(buffer);
   if(meta){
    let h="<details open><summary>DOCX Metadata</summary>";
    for(let k in meta) h+=k+": "+meta[k]+"<br>";
    h+="</details>";
    div.innerHTML+=h;
   }
  }

  /* JPEG */
  if(file.type==="image/jpeg"){
    let ex=parseEXIF(buffer);
    if(ex){
     let h="<details open><summary>EXIF</summary>";
     for(let k in ex) h+=k+": "+ex[k]+"<br>";
     h+="</details>";
     div.innerHTML+=h;
    }
  }

  /* PNG */
  if(file.type==="image/png"){
   let t=parsePNG(buffer);
   if(t.length){
     div.innerHTML+=`<details><summary>PNG Text</summary>${t.join("<br>")}</details>`;
   }
  }

 }
}

</script>
</body>
</html>